// ------------------- MOTORS -------------------
#define ENA  25  
#define IN1  26
#define IN2  27
#define ENB  14
#define IN3  12
#define IN4  13  
 

int x = 50, y = 50;
int Speed = 150;         


// ------------------- MQ SENSORS -------------------
#define MQ135_PIN 34
#define MQ2_PIN   35
#define RL 10000.0  // 10kΩ load resistor

float R0_MQ135 = 10000.0;  
float R0_MQ2   = 10000.0;

float cleanAir_MQ135 = 3.6;
float cleanAir_MQ2   = 9.8;

// ------------------- WIFI + BLYNK -------------------
