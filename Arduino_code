// ------------------- FUNCTIONS -------------------
void calibrateSensor(int pin, float cleanAirFactor, float &R0) {
  long avgADC = 0;
  for (int i = 0; i < 100; i++) {
    avgADC += analogRead(pin);
    delay(50);
  }
  avgADC /= 100;
  float Vout = (avgADC / 4095.0) * 3.3;
  float Rs = ((3.3 - Vout) / Vout) * RL;
  R0 = Rs / cleanAirFactor;

  Serial.print("Sensor on pin ");
  Serial.print(pin);
  Serial.print(" calibrated, R0 = ");
  Serial.println(R0);
}

float readGasPPM(int pin, float R0, float a, float b) {
  int adcValue = analogRead(pin);
  float Vout = (adcValue / 4095.0) * 3.3;
  float Rs = ((3.3 - Vout) / Vout) * RL;
  float ratio = Rs / R0;
  float ppm = a * pow(ratio, b);
  return ppm;
}

// ------------------- BLYNK HANDLERS -------------------
BLYNK_WRITE(V0) { x = param.asInt(); }        
BLYNK_WRITE(V1) { y = param.asInt(); }         
BLYNK_WRITE(V2) { Speed = param.asInt(); }     


// ------------------- MOTOR CONTROL -------------------
void Forward() {
  analogWrite(ENA, Speed);
  analogWrite(ENB, Speed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void Backward() {
  analogWrite(ENA, Speed);
  analogWrite(ENB, Speed);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, HIGH);
}

void Right() {
  analogWrite(ENA, Speed);
  analogWrite(ENB, Speed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void Left() {
  analogWrite(ENA, Speed);
  analogWrite(ENB, Speed);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void carStop() {
  analogWrite(ENA, 0);
  analogWrite(ENB, 0);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

void Control_Car() {
  if (y > 70) {
    Forward();
  } else if (y < 30) {
    Backward();
  } else if (x < 30) {
    Left();
  } else if (x > 70) {
    Right();
  } else {
    carStop();
  }
}

// ------------------- SETUP -------------------
void setup() {
  Serial.begin(115200);

  // Motor pins
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
 

  // Connect Blynk
  Serial.println("Connecting to WiFi & Blynk...");
  Blynk.begin(auth, ssid, pass, "blynk.cloud", 80);
  Serial.println("WiFi connected!");

  // Calibrate gas sensors
  calibrateSensor(MQ135_PIN, cleanAir_MQ135, R0_MQ135);
  calibrateSensor(MQ2_PIN, cleanAir_MQ2, R0_MQ2);
}

// ------------------- LOOP -------------------
void loop() {
  Blynk.run();
  

  // Car control
  Control_Car();

  // Gas sensor readings
  float ppm_MQ135 = readGasPPM(MQ135_PIN, R0_MQ135, 100.0, -2.0);  
  float ppm_MQ2   = readGasPPM(MQ2_PIN,   R0_MQ2,   200.0, -2.1);

  // Send to Blynk
  Blynk.virtualWrite(V3, ppm_MQ135);
  Blynk.virtualWrite(V4, ppm_MQ2);

  // Print to Serial   
  Serial.print("MQ135 (Air Quality/NH3) PPM: ");
  Serial.println   (ppm_MQ135);
  Serial.print("MQ2 (Smoke/LPG) PPM: ");
  Serial.println(ppm_MQ2);

  // Alert condition
  if (ppm_MQ135 > 5 || ppm_MQ2 > 10) {
    Blynk.logEvent("gas_alert", "Dangerous gas level detected!");
  }

  delay(500);
}
